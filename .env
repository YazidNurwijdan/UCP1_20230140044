import requests
from bs4 import BeautifulSoup
from pymongo import MongoClient
from datetime import datetime

print("1. Starting script...")

# Koneksi MongoDB
print("2. Connecting to MongoDB...")
try:
    client = MongoClient("mongodb+srv://yaazziid:123@yaazziid.cgktlzj.mongodb.net/", serverSelectionTimeoutMS=5000)
    db = client["cnbc_news"]
    collection = db["environment"]
    print("3. MongoDB connected!")
except Exception as e:
    print(f"MongoDB connection error: {e}")

headers = {
    "User-Agent": "Mozilla/5.0"
}

BASE_URL = "https://www.cnbcindonesia.com/news"

def get_article_links():
    print("4. Getting article links...")
    try:
        res = requests.get(BASE_URL, headers=headers, timeout=10)
        soup = BeautifulSoup(res.text, "html.parser")

        links = []
        articles = soup.find_all("a", href=True)
        print(f"   Found {len(articles)} article links")

        for a in articles:
            link = a["href"]
            if "/news/" in link:
                if link.startswith("/"):
                    link = "https://www.cnbcindonesia.com" + link
                links.append(link)

        return list(set(links))
    except Exception as e:
        print(f"Error in get_article_links: {e}")
        return []


def get_article_detail(url):
    try:
        res = requests.get(url, headers=headers, timeout=10)
        soup = BeautifulSoup(res.text, "html.parser")

        # Judul
        title = soup.find("h1").text if soup.find("h1") else None

        # Tanggal
        date = soup.find("div", class_="date")
        date = date.text if date else None

        # Author
        author = soup.find("div", class_="author")
        author = author.text if author else None

        # Thumbnail
        thumbnail = soup.find("img")
        thumbnail = thumbnail["src"] if thumbnail else None

        # Isi berita
        content_div = soup.find("div", class_="detail_text")
        content = content_div.text.strip() if content_div else None

        # Tag kategori
        tags = []
        tag_div = soup.find_all("a", class_="tag")
        for t in tag_div:
            tags.append(t.text)

        data = {
            "url": url,
            "judul": title,
            "tanggal": date,
            "author": author,
            "tag": tags,
            "isi": content,
            "thumbnail": thumbnail,
            "created_at": datetime.now()
        }

        return data

    except Exception as e:
        print("Error:", e)
        return None


def main():
    links = get_article_links()
    print(f"5. Processing {len(links)} unique links")

    for link in links[:5]:  # Limit to first 5
        if collection.find_one({"url": link}):
            print(f"   Skipping (already exists): {link}")
            continue

        data = get_article_detail(link)

        if data:
            collection.insert_one(data)
            print("Saved:", data["judul"])


if __name__ == "__main__":
    main()
    print("Done!")
